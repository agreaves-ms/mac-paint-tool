{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron: Main Process",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron-forge",
      "args": ["start"],
      "cwd": "${workspaceFolder}",
      "outFiles": ["${workspaceFolder}/.vite/build/**/*.js"],
      "sourceMaps": true,
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Electron: Renderer Process",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/src/renderer",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///./src/renderer/*": "${workspaceFolder}/src/renderer/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Electron: Full Debug",
      "configurations": ["Electron: Main Process", "Electron: Renderer Process"]
    }
  ]
}
